        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Sample Food Delivery Dataset\n",
        "data = {\n",
        "    \"Order_ID\": [101,102,103,104,105,106,107,108,109,110],\n",
        "    \"Time\": [\"12:30\",\"13:00\",\"18:45\",\"19:00\",\"20:15\",\n",
        "             \"12:45\",\"18:30\",\"21:00\",\"13:15\",\"19:30\"],\n",
        "    \"Location\": [\"Chennai\",\"Coimbatore\",\"Chennai\",\"Madurai\",\"Chennai\",\n",
        "                 \"Coimbatore\",\"Madurai\",\"Chennai\",\"Madurai\",\"Coimbatore\"],\n",
        "    \"Item\": [\"Pizza\",\"Burger\",\"Pizza\",\"Biryani\",\"Burger\",\n",
        "             \"Pizza\",\"Biryani\",\"Pizza\",\"Burger\",\"Biryani\"],\n",
        "    \"Amount\": [250,180,300,220,200,260,240,320,190,230]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(\"FOOD DELIVERY DATASET\")\n",
        "print(df)\n",
        "\n",
        "# Most Popular Dish\n",
        "popular = df[\"Item\"].value_counts()\n",
        "\n",
        "print(\"\\nMost Popular Dishes\")\n",
        "print(popular)\n",
        "\n",
        "# Peak Order Times\n",
        "df[\"Hour\"] = df[\"Time\"].str.split(\":\").str[0].astype(int)\n",
        "peak = df[\"Hour\"].value_counts().sort_index()\n",
        "\n",
        "print(\"\\nPeak Order Hours\")\n",
        "print(peak)\n",
        "\n",
        "# Orders by Location\n",
        "location_orders = df[\"Location\"].value_counts()\n",
        "\n",
        "print(\"\\nOrders by Location\")\n",
        "print(location_orders)\n",
        "\n",
        "# Total Sales\n",
        "print(\"\\nTotal Sales =\", df[\"Amount\"].sum())\n",
        "\n",
        "# Dashboard\n",
        "plt.figure(figsize=(12,4))\n",
        "\n",
        "plt.subplot(1,3,1)\n",
        "popular.plot(kind=\"bar\")\n",
        "plt.title(\"Popular Dishes\")\n",
        "\n",
        "plt.subplot(1,3,2)\n",
        "peak.plot(kind=\"bar\")\n",
        "plt.title(\"Peak Hours\")\n",
        "\n",
        "plt.subplot(1,3,3)\n",
        "location_orders.plot(kind=\"bar\")\n",
        "plt.title(\"Orders by Location\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
